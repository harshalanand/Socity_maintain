# Aashiyana Homes - Society Management System v2.0
# Environment Configuration File

# Database
DATABASE_URL=sqlite:///./aashiyana.db
# For PostgreSQL: DATABASE_URL=postgresql://user:password@localhost/aashiyana

# Server
HOST=0.0.0.0
PORT=8000
DEBUG=True

# Security
SECRET_KEY=aashiyana-super-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# CORS
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173","http://localhost:8000"]

# Logging
LOG_LEVEL=INFO
